{
  "name": "claude-reset-notifier",
  "displayName": "Claude Code Reset Notifier",
  "description": "Get a 10-minute warning before your Claude Code quota resets",
  "version": "0.1.0",
  "publisher": "your-publisher-id",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "keywords": ["claude", "claude code", "anthropic", "quota", "notification"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Claude Reset Notifier",
      "properties": {
        "claudeReset.warningMinutes": {
          "type": "number",
          "default": 10,
          "description": "Minutes before quota reset to send the warning notification"
        },
        "claudeReset.lowUsageThreshold": {
          "type": "number",
          "default": 20,
          "description": "If message count in window is below this, show the 'use it or lose it' nudge"
        },
        "claudeReset.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable all notifications"
        },
        "claudeReset.tokenLimit": {
          "type": "number",
          "default": 0,
          "description": "Your plan's token limit per 5-hour window (0 = show count only, no percentage). Suggested values: Claude Max 5x → 500000, Claude Max 1x → 100000, Pro → 45000"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test:unit": "jest"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "@types/jest": "^29.0.0",
    "typescript": "^5.3.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0"
  }
}
